{
  "name": "@wearos-claude/backend",
  "version": "0.1.0",
  "private": true,
  "description": "Local Claude Code usage telemetry API for the wearos-claude Wear OS dashboard",
  "type": "module",
  "main": "dist/backend/src/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/backend/src/server.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "probe": "tsx src/cli/probe.ts"
  },
  "dependencies": {
    "fastify": "^4.28.1",
    "@fastify/cors": "^9.0.1",
    "pino-pretty": "^11.2.2"
  },
  "devDependencies": {
    "@types/node": "^20.14.10",
    "tsx": "^4.16.2",
    "typescript": "^5.5.3"
  },
  "engines": {
    "node": ">=20"
  }
}
