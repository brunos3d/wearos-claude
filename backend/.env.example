# wearos-claude backend configuration.
# Copy this file to `.env` and edit. Every value has a sane default — only
# set what you need.
#
# Everything not listed here is auto-detected:
#   • 5-hour and 7-day usage  → Anthropic ratelimit headers
#   • plan tier (Pro/Max/Team) → ~/.claude/.credentials.json
#   • reset times             → Anthropic ratelimit headers
#   • current window length   → fixed at 5 hours by Anthropic
# You should never have to hand-tune token budgets.

# ----- HTTP -----
# Use 0.0.0.0 so the watch on your LAN can reach the server.
HOST=0.0.0.0
PORT=47823

# ----- Claude Code data sources -----
# Override only if Claude Code lives somewhere unusual (defaults to ~/.claude).
CLAUDE_HOME=

# ----- OAuth probe -----
# The backend reads authoritative 5h / 7d usage from Anthropic's ratelimit
# headers by sending a 1-token probe to /v1/messages. Each probe costs ONE
# message from your 5-hour quota — the default 10 minute cadence works out
# to ~30 probes per window.
#
# Set OAUTH_PROBE_DISABLED=1 to turn the probe off entirely; the backend
# will then estimate usage from local JSONL transcripts against the limits
# inferred from your subscription tier (rougher, but costs nothing).
OAUTH_PROBE_INTERVAL_MINUTES=10
OAUTH_PROBE_DISABLED=

# ----- LAN auth -----
# Optional shared secret. When set, /usage requires header
#   x-wearos-claude-token: <value>
# Generate one with `openssl rand -hex 32` and bake it into the APK with
#   scripts/build-apk.sh
AUTH_TOKEN=
